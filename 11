local function BuildPanel(w,h,zBase,parent)
	parent=parent or ScreenGui
	local container=Instance.new("Frame"); container.Size=UDim2.new(0,w,0,h); container.BackgroundTransparency=1
	container.BorderSizePixel=0; container.ZIndex=zBase; container.ClipsDescendants=false; container.Parent=parent
	local glass=Instance.new("Frame"); glass.Name="Glass"; glass.Size=UDim2.new(1,0,1,0); glass.BackgroundColor3=C.Background
	glass.BackgroundTransparency=State.guiOpacity; glass.BorderSizePixel=0; glass.ZIndex=zBase; glass.ClipsDescendants=true; glass.Parent=container
	Instance.new("UICorner",glass).CornerRadius=UDim.new(0,16)
	-- Добавляем обводку как в главном меню
	local glassStroke = Instance.new("UIStroke")
	glassStroke.Color = C.DashColor
	glassStroke.Thickness = 2
	glassStroke.Transparency = 0.3
	glassStroke.Parent = glass
	
	local snowC=Instance.new("Frame"); snowC.Size=UDim2.new(1,0,1,0); snowC.BackgroundTransparency=1; snowC.ClipsDescendants=true; snowC.ZIndex=zBase; snowC.Parent=glass
	Instance.new("UICorner",snowC).CornerRadius=UDim.new(0,16)
	CreateSnowSystem(snowC,zBase,25)
	local overlay=Instance.new("Frame"); overlay.Size=UDim2.new(1,0,1,0); overlay.BackgroundColor3=C.Background
	overlay.BackgroundTransparency=0.85; overlay.BorderSizePixel=0; overlay.ZIndex=zBase+1; overlay.Parent=glass
	Instance.new("UICorner",overlay).CornerRadius=UDim.new(0,16)
	local dashClip = Instance.new("Frame"); dashClip.Name="DashClip"; dashClip.Size=UDim2.new(1,0,1,0)
	dashClip.BackgroundTransparency=1; dashClip.BorderSizePixel=0; dashClip.ZIndex=zBase+3; dashClip.ClipsDescendants=true; dashClip.Parent=glass
	Instance.new("UICorner",dashClip).CornerRadius=UDim.new(0,16)
	local _,dashes = CreateDashedBorder(dashClip, zBase)
	table.insert(GUI.glassPanels,{glass=glass,overlay=overlay,dashes=dashes})
	return container,glass,overlay end

local function BuildHeader(container,title,titleColor,zBase)
	local header=Instance.new("Frame"); header.Size=UDim2.new(1,0,0,50); header.BackgroundColor3=C.BackgroundLight
	header.BackgroundTransparency=0.35; header.BorderSizePixel=0; header.ZIndex=zBase+2; header.Parent=container
	Instance.new("UICorner",header).CornerRadius=UDim.new(0,16)
	local fix=Instance.new("Frame"); fix.Size=UDim2.new(1,0,0,22); fix.Position=UDim2.new(0,0,1,-22)
	fix.BackgroundColor3=C.BackgroundLight; fix.BackgroundTransparency=0.35; fix.BorderSizePixel=0; fix.ZIndex=zBase+2; fix.Parent=header
	local titleLbl=Instance.new("TextLabel"); titleLbl.Size=UDim2.new(0.55,0,1,0); titleLbl.Position=UDim2.new(0,14,0,0)
	titleLbl.BackgroundTransparency=1; titleLbl.Text=title; titleLbl.TextColor3=titleColor or C.Text
	titleLbl.TextSize=14; titleLbl.Font=PIXEL_FONT; titleLbl.TextXAlignment=Enum.TextXAlignment.Left; titleLbl.ZIndex=zBase+3; titleLbl.Parent=header
	
	local closeBtn = Instance.new("TextButton")
