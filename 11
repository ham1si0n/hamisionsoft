-- AIMBOT
do local function IsVisible(part) if not Aimbot.visCheck then return true end; if not rootPart then return false end
		local origin=rootPart.Position+Vector3.new(0,2,0); local params=RaycastParams.new()
		params.FilterDescendantsInstances={character,part.Parent}; params.FilterType=Enum.RaycastFilterType.Exclude
		return workspace:Raycast(origin,(part.Position-origin),params)==nil end
	local function GetTarget() if not Aimbot.enabled then return nil end
		local center=Vector2.new(camera.ViewportSize.X/2,camera.ViewportSize.Y/2); local cd=Aimbot.fov; local ct=nil
		for _,target in pairs(Players:GetPlayers()) do if target==player then continue end
			if Aimbot.teamCheck and target.Team==player.Team and player.Team~=nil then continue end; if IsImmortal(target) then continue end
			local ch=target.Character; if not ch then continue end; local part=ch:FindFirstChild(Aimbot.targetPart) or ch:FindFirstChild("Head")
			if not part then continue end; local h2=ch:FindFirstChild("Humanoid"); if not h2 or h2.Health<=0 then continue end
			local sp,on=camera:WorldToViewportPoint(part.Position); if not on then continue end; if not IsVisible(part) then continue end
			local dist=(Vector2.new(sp.X,sp.Y)-center).Magnitude; if dist<cd then cd=dist; ct=target end end; return ct end
	pcall(function() local circle=Drawing.new("Circle"); circle.Visible=false; circle.Radius=Aimbot.fov; circle.Color=Color3.fromRGB(255,255,255)
		circle.Thickness=1.5; circle.Transparency=0.5; circle.Filled=false; Aimbot.fovCircle=circle end)
	function Aimbot.Update(dt)
		if Aimbot.fovCircle then local center=Vector2.new(camera.ViewportSize.X/2,camera.ViewportSize.Y/2)
			Aimbot.fovCircle.Position=center; Aimbot.fovCircle.Radius=Aimbot.fov; Aimbot.fovCircle.Visible=Aimbot.fovVisible and Aimbot.enabled end
		if not Aimbot.enabled then return end
		local kp = false
		if typeof(Aimbot.key) == "EnumItem" and Aimbot.key.EnumType == Enum.KeyCode then
			kp = UserInputService:IsKeyDown(Aimbot.key)
		else
			pcall(function() kp = UserInputService:IsMouseButtonPressed(Aimbot.key) end)
		end
		if not kp then Aimbot.locked=nil; if Aimbot.statusLabel then Aimbot.statusLabel.Text="TARGET: NONE"; Aimbot.statusLabel.TextColor3=C.TextDim end; return end
		if Aimbot.locked then local ch=Aimbot.locked.Character; local part=ch and(ch:FindFirstChild(Aimbot.targetPart) or ch:FindFirstChild("Head"))
			if not part or not ch:FindFirstChild("Humanoid") or ch.Humanoid.Health<=0 then Aimbot.locked=nil end end
		if not Aimbot.locked then Aimbot.locked=GetTarget() end
		if Aimbot.locked then local ch=Aimbot.locked.Character; local part=ch and(ch:FindFirstChild(Aimbot.targetPart) or ch:FindFirstChild("Head"))
			if not part then Aimbot.locked=nil; return end; local tp=part.Position
			if Aimbot.prediction then local r=ch:FindFirstChild("HumanoidRootPart"); if r then tp=tp+r.AssemblyLinearVelocity*Aimbot.predictAmount end end
			local _,on=camera:WorldToViewportPoint(tp); if on then local lf=math.clamp(Aimbot.smooth*(dt or 0.016)*60,0,1)
				camera.CFrame=camera.CFrame:Lerp(CFrame.new(camera.CFrame.Position,tp),lf)
				if Aimbot.statusLabel and rootPart then local dist=math.floor((rootPart.Position-part.Position).Magnitude)
					Aimbot.statusLabel.Text="TARGET: "..Aimbot.locked.DisplayName.." ["..dist.."M]"; Aimbot.statusLabel.TextColor3=C.Red end end
		else if Aimbot.statusLabel then Aimbot.statusLabel.Text="SEARCHING..."; Aimbot.statusLabel.TextColor3=C.Orange end end end end

