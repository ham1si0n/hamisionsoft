local function ToggleMenu() State.guiOpen=not State.guiOpen
	if State.guiOpen then
		lastIconPos.X=IconButton.Position.X.Offset; lastIconPos.Y=IconButton.Position.Y.Offset; lastIconPos.YScale=IconButton.Position.Y.Scale
		IconButton.Visible=false
		MainContainer.Visible=true
		MainContainer.Size=UDim2.new(0,60,0,60)
		MainContainer.Position=UDim2.new(0,lastIconPos.X,lastIconPos.YScale,lastIconPos.Y)
		local targetX = lastIconPos.X + 70
		local targetY = lastIconPos.Y - 250
		local screenH = camera.ViewportSize.Y
		local menuH = 560
		local absY = lastIconPos.YScale * screenH + targetY
		if absY < 10 then targetY = targetY + (10 - absY) end
		if absY + menuH > screenH - 10 then targetY = targetY - (absY + menuH - screenH + 10) end
		TweenService:Create(MainContainer,TweenInfo.new(0.5,Enum.EasingStyle.Quint,Enum.EasingDirection.Out),{
			Size=UDim2.new(0,320,0,560),Position=UDim2.new(0,targetX,lastIconPos.YScale,targetY)}):Play()
	else
		CloseAllSubMenus()
		if plVisible then plVisible=false
			PLFrame.Visible=false; PLFrame.Size=UDim2.new(0,380,0,460) end
		ToggleFlyMini(false)
		TweenService:Create(MainContainer,TweenInfo.new(0.4,Enum.EasingStyle.Quint,Enum.EasingDirection.In),{
			Size=UDim2.new(0,60,0,60),
			Position=UDim2.new(0,lastIconPos.X,lastIconPos.YScale,lastIconPos.Y)}):Play()
		task.delay(0.4,function()
			MainContainer.Visible=false; MainContainer.Size=UDim2.new(0,320,0,560)
			IconButton.Visible=true; IconButton.ImageTransparency=0
		end)
	end
