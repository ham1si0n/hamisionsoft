local function MakeGUILine(x1,y1,x2,y2,color,thickness,transparency)
	local f=Instance.new("Frame"); f.BackgroundColor3=color; f.BackgroundTransparency=transparency or 0; f.BorderSizePixel=0; f.ZIndex=1001
	local dx,dy=x2-x1,y2-y1; local len=math.sqrt(dx*dx+dy*dy)
	f.Size=UDim2.new(0,math.max(len,thickness),0,thickness); f.Position=UDim2.new(0,(x1+x2)/2-math.max(len,thickness)/2,0,(y1+y2)/2-thickness/2)
	f.Rotation=math.deg(math.atan2(dy,dx)); f.Parent=CHContainer; return f end

local function MakeGUICircle(cx,cy,radius,color,thickness,filled,transparency)
	if filled then local f=Instance.new("Frame"); f.Size=UDim2.new(0,radius*2,0,radius*2); f.Position=UDim2.new(0,cx-radius,0,cy-radius)
		f.BackgroundColor3=color; f.BackgroundTransparency=transparency or 0; f.BorderSizePixel=0; f.ZIndex=1001
		Instance.new("UICorner",f).CornerRadius=UDim.new(1,0); f.Parent=CHContainer; return f
	else local frames={}; local segs=math.max(20,math.floor(radius*1.2))
		for i=0,segs-1 do local a1,a2=(i/segs)*math.pi*2,((i+1)/segs)*math.pi*2
			table.insert(frames,MakeGUILine(cx+math.cos(a1)*radius,cy+math.sin(a1)*radius,cx+math.cos(a2)*radius,cy+math.sin(a2)*radius,color,thickness,transparency))
		end; return frames end end

local function CreatePropeller()
	if Crosshair.propFrame and Crosshair.propFrame.Parent then Crosshair.propFrame:Destroy(); Crosshair.propFrame=nil; Crosshair.propBlades={} end
	if not Crosshair.enabled then return end
	local vp=camera.ViewportSize; local cx,cy=vp.X/2,vp.Y/2; local sz=Crosshair.size; local th=Crosshair.thick
	local col=Crosshair.color; local tr=1-Crosshair.opacity; local armLen=sz*4; local hookLen=sz*2; local halfW=armLen+hookLen+th*2
	local pivot=Instance.new("Frame"); pivot.Name="SwastikaPivot"; pivot.Size=UDim2.new(0,halfW*2,0,halfW*2)
	pivot.Position=UDim2.new(0,cx-halfW,0,cy-halfW); pivot.BackgroundTransparency=1; pivot.BorderSizePixel=0; pivot.ZIndex=1001; pivot.ClipsDescendants=false; pivot.Parent=CHContainer
	local function MS(x1,y1,x2,y2,isO) local f=Instance.new("Frame"); local ax1,ay1,ax2,ay2=halfW+x1,halfW+y1,halfW+x2,halfW+y2
		local ddx,ddy=ax2-ax1,ay2-ay1; local l=math.sqrt(ddx*ddx+ddy*ddy)
		f.Size=UDim2.new(0,math.max(l,1),0,isO and(th+2)or th); f.Position=UDim2.new(0,(ax1+ax2)/2-math.max(l,1)/2,0,(ay1+ay2)/2-(isO and(th+2)or th)/2)
		f.Rotation=math.deg(math.atan2(ddy,ddx)); f.BackgroundColor3=isO and Color3.fromRGB(0,0,0)or col
		f.BackgroundTransparency=tr; f.BorderSizePixel=0; f.ZIndex=isO and 1001 or 1002; f.Parent=pivot; return f end
	local segs={{0,0,0,-armLen},{0,-armLen,hookLen,-armLen},{0,0,armLen,0},{armLen,0,armLen,hookLen},
		{0,0,0,armLen},{0,armLen,-hookLen,armLen},{0,0,-armLen,0},{-armLen,0,-armLen,-hookLen}}
	for _,s in ipairs(segs) do if Crosshair.outline then table.insert(Crosshair.propBlades,MS(s[1],s[2],s[3],s[4],true)) end
		table.insert(Crosshair.propBlades,MS(s[1],s[2],s[3],s[4],false)) end
	local dot=Instance.new("Frame"); dot.Size=UDim2.new(0,th*2,0,th*2); dot.Position=UDim2.new(0,halfW-th,0,halfW-th)
	dot.BackgroundColor3=col; dot.BackgroundTransparency=tr; dot.BorderSizePixel=0; dot.ZIndex=1003
