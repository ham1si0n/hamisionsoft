-- SPEED BYPASS
local function SpeedBypass()
	if not State.speedBypassEnabled then return end
	if not humanoid then return end
	
	State.realWalkSpeed = humanoid.WalkSpeed
	
	local speedRemote = nil
	for _, v in pairs(ReplicatedStorage:GetDescendants()) do
		if v:IsA("RemoteEvent") and (v.Name:lower():match("speed") or v.Name:lower():match("walk")) then
			speedRemote = v
			break
		end
	end
	
	if speedRemote then
		task.spawn(function()
			while State.speedBypassEnabled do
				pcall(function()
