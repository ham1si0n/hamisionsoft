function ConfigSystem.SaveToFile(name)
	if not hasFileSystem then return false,"No filesystem" end; EnsureFolder()
	local ok2,err=pcall(function() writefile(CONFIG_FOLDER.."/"..name..".json",HttpService:JSONEncode(ConfigSystem.GatherConfig())) end)
	if ok2 then ConfigSystem.currentProfile=name; return true,"Saved: "..name else return false,"Error: "..tostring(err) end end

function ConfigSystem.LoadFromFile(name)
	if not hasFileSystem then return false,"No filesystem" end
	local path=CONFIG_FOLDER.."/"..name..".json"
	if not pcall(function() assert(isfile(path)) end) then return false,"Not found: "..name end
	local cfg; local ok2=pcall(function() cfg=HttpService:JSONDecode(readfile(path)) end)
	if not ok2 then return false,"Parse error" end
	if ConfigSystem.ApplyConfig(cfg) then ConfigSystem.currentProfile=name; return true,"Loaded: "..name end
	return false,"Apply error" end

function ConfigSystem.DeleteProfile(name)
	if not hasFileSystem then return false,"No filesystem" end
	pcall(function() if isfile(CONFIG_FOLDER.."/"..name..".json") then delfile(CONFIG_FOLDER.."/"..name..".json") end end)
	return true,"Deleted: "..name end

function ConfigSystem.GetProfiles()
	local p={}; if not hasFileSystem then return p end
	pcall(function() if isfolder(CONFIG_FOLDER) then
		for _,f in ipairs(listfiles(CONFIG_FOLDER)) do local n=f:match("([^/\\]+)%.json$"); if n then table.insert(p,n) end end
	end end); return p end

