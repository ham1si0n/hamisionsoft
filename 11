local function SafeCreateTracerLine() local line=nil; pcall(function() line=Drawing.new("Line"); line.Visible=false; line.Color=ESP.settings.tracerColor
	line.Thickness=1.5; line.Transparency=0.7; line.ZIndex=5 end); return line end
local function SafeRemoveDrawing(obj) if obj then pcall(function() obj:Remove() end) end end
local function GetTracerOriginPoint() local vp=camera.ViewportSize; local o=ESP.settings.tracerOrigin
	if o=="Bottom" then return Vector2.new(vp.X/2,vp.Y) elseif o=="Top" then return Vector2.new(vp.X/2,0) else return Vector2.new(vp.X/2,vp.Y/2) end end

local function RemoveESP(target)
	if ESP.connections[target] then for _,conn in ipairs(ESP.connections[target]) do pcall(function() conn:Disconnect() end) end; ESP.connections[target]=nil end
	if ESP.objects[target] then local obj=ESP.objects[target]
		pcall(function() if obj.bb and obj.bb.Parent then obj.bb:Destroy() end end)
		pcall(function() if obj.box and obj.box.Parent then obj.box:Destroy() end end)
		if obj.skeleton then
			for _, line in pairs(obj.skeleton) do
				pcall(function() line:Remove() end)
			end
		end
		if obj.glow and obj.glow.Parent then obj.glow:Destroy() end
		SafeRemoveDrawing(obj.tracerLine); ESP.objects[target]=nil end end

local function RemoveChams(target)
	if ESP.chamsConnections[target] then for _,conn in ipairs(ESP.chamsConnections[target]) do pcall(function() conn:Disconnect() end) end; ESP.chamsConnections[target]=nil end
	if ESP.chamsObjects[target] then for _,cp in pairs(ESP.chamsObjects[target]) do pcall(function() if cp and cp.Parent then cp:Destroy() end end) end; ESP.chamsObjects[target]=nil end
end

local function CreateSkeleton(target, obj)
	if not ESP.settings.showSkeleton then return end
	local char = target.Character
	if not char then return end
	
	local skeleton = {}
	local success, err = pcall(function()
		local function addLine()
			return Drawing.new("Line")
		end
		
		for i = 1, 5 do
			local line = addLine()
			line.Visible = false
			line.Color = ESP.settings.boxColor
			line.Thickness = 1.5
			line.Transparency = 0.5
			line.ZIndex = 5
			table.insert(skeleton, line)
		end
	end)
	
	if not success then
		obj.skeleton = nil
		return
	end
	
	obj.skeleton = skeleton
end

local function UpdateSkeleton(target, obj)
	if not ESP.settings.showSkeleton then 
		if obj.skeleton then
			for _, line in pairs(obj.skeleton) do
				pcall(function() line.Visible = false end)
			end
		end
		return 
	end
	if not obj.skeleton then CreateSkeleton(target, obj) end
	if not obj.skeleton then return end
	
	local char = target.Character
	if not char then return end
	
	local function getPartPos(partName)
		local part = char:FindFirstChild(partName)
		if part then
			local pos, onScreen = camera:WorldToViewportPoint(part.Position)
			if onScreen then
				return Vector2.new(pos.X, pos.Y)
			end
		end
		return nil
	end
	
	local headPos = getPartPos("Head")
	local torsoPos = getPartPos("Torso") or getPartPos("UpperTorso")
	local leftArmPos = getPartPos("Left Arm") or getPartPos("LeftHand")
	local rightArmPos = getPartPos("Right Arm") or getPartPos("RightHand")
	local leftLegPos = getPartPos("Left Leg") or getPartPos("LeftFoot")
	local rightLegPos = getPartPos("Right Leg") or getPartPos("RightFoot")
	
	local lines = obj.skeleton
	local idx = 1
	
	pcall(function()
		if headPos and torsoPos then
			lines[idx].Visible = true
			lines[idx].From = headPos
			lines[idx].To = torsoPos
			lines[idx].Color = ESP.settings.boxColor
			idx = idx + 1
		end
		
		if torsoPos and leftArmPos then
			lines[idx].Visible = true
			lines[idx].From = torsoPos
			lines[idx].To = leftArmPos
			lines[idx].Color = ESP.settings.boxColor
			idx = idx + 1
		end
		
		if torsoPos and rightArmPos then
			lines[idx].Visible = true
			lines[idx].From = torsoPos
			lines[idx].To = rightArmPos
			lines[idx].Color = ESP.settings.boxColor
			idx = idx + 1
		end
		
		if torsoPos and leftLegPos then
			lines[idx].Visible = true
			lines[idx].From = torsoPos
			lines[idx].To = leftLegPos
			lines[idx].Color = ESP.settings.boxColor
			idx = idx + 1
		end
		
		if torsoPos and rightLegPos then
			lines[idx].Visible = true
			lines[idx].From = torsoPos
			lines[idx].To = rightLegPos
			lines[idx].Color = ESP.settings.boxColor
			idx = idx + 1
		end
	end)
	
	for i = idx, #lines do
		pcall(function() lines[i].Visible = false end)
	end
end

