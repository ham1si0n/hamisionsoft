local function MakeSubMenu(titleText,titleColor,w,h)
	local cont=Instance.new("Frame"); cont.Size=UDim2.new(0,w,0,h)
	cont.Position=UDim2.new(0.5,-w/2,0.5,-h/2)
	cont.BackgroundTransparency=1; cont.Visible=false; cont.ZIndex=14; cont.Parent=ScreenGui
	local container,glass,overlay=BuildPanel(w,h,14,nil); glass.Parent=cont
	local header,closeBtn,_,headerLbl=BuildHeader(cont,titleText,titleColor,15)
	local scroll=BuildScroll(cont,15,58); MakeDraggable(header,cont)
	
	local menuData = {visible=false, close=nil}
	
	local function Open()
		CloseAllSubMenus()
		menuData.visible=true; cont.Visible=true
		cont.Size=UDim2.new(0,w*0.5,0,h*0.5)
		cont.Position=UDim2.new(0.5,-w*0.25,0.5,-h*0.25)
		TweenService:Create(cont,TweenInfo.new(0.5,Enum.EasingStyle.Quint,Enum.EasingDirection.Out),{
			Size=UDim2.new(0,w,0,h), Position=UDim2.new(0.5,-w/2,0.5,-h/2)}):Play()
	end
	
	local function Close()
		menuData.visible=false
		TweenService:Create(cont,TweenInfo.new(0.4,Enum.EasingStyle.Quint,Enum.EasingDirection.In),{
			Size=UDim2.new(0,w*0.5,0,h*0.5),
			Position=UDim2.new(0.5,-w*0.25,0.5,-h*0.25)}):Play()
		task.delay(0.4,function() if not menuData.visible then cont.Visible=false end end)
	end
	
	menuData.close = Close
	closeBtn.MouseButton1Click:Connect(Close)
	local function Toggle3() if menuData.visible then Close() else Open() end end
	table.insert(GUI.allSubMenus, menuData)
	RegTheme(function() scroll.ScrollBarImageColor3=C.DashColor; headerLbl.TextColor3=titleColor or C.Text; closeBtn.BackgroundColor3=C.CloseBtn end)
	return scroll,Toggle3,cont end

