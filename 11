local function CreateESP(target)
	if target==player then return end; RemoveESP(target)
	local char=target.Character; if not char then return end
	local r2=char:FindFirstChild("HumanoidRootPart"); local h2=char:FindFirstChild("Humanoid"); local head=char:FindFirstChild("Head")
	if not r2 or not h2 or not head then return end; local s=ESP.settings
	if s.teamCheck and target.Team==player.Team and player.Team~=nil then return end; if h2.Health<=0 then return end
	ESP.connections[target]={}
	table.insert(ESP.connections[target],h2.Died:Connect(function() task.delay(0.5,function() RemoveESP(target) end) end))
	table.insert(ESP.connections[target],char.AncestryChanged:Connect(function(_,np) if np==nil then task.delay(0.1,function() RemoveESP(target) end) end end))
	local bb,nameLabel,distLabel=nil,nil,nil
	if s.showNames or s.showDistance then pcall(function() bb=Instance.new("BillboardGui"); bb.Adornee=head; bb.Size=UDim2.new(0,150,0,50)
		bb.StudsOffset=Vector3.new(0,3,0); bb.AlwaysOnTop=true; bb.MaxDistance=s.maxDistance; bb.Parent=head
		if s.showNames then nameLabel=Instance.new("TextLabel"); nameLabel.Size=UDim2.new(1,0,0.5,0); nameLabel.BackgroundTransparency=1
			nameLabel.Text=target.DisplayName; nameLabel.TextColor3=s.nameColor; nameLabel.TextStrokeTransparency=0.3
			nameLabel.TextSize=s.textSize; nameLabel.Font=PIXEL_FONT; nameLabel.Parent=bb end
		if s.showDistance then distLabel=Instance.new("TextLabel"); distLabel.Size=UDim2.new(1,0,0.5,0); distLabel.Position=UDim2.new(0,0,0.5,0)
			distLabel.BackgroundTransparency=1; distLabel.Text="[0M]"; distLabel.TextColor3=s.distColor; distLabel.TextStrokeTransparency=0.3
			distLabel.TextSize=s.textSize-2; distLabel.Font=PIXEL_FONT; distLabel.Parent=bb end end) end
	local box,boxFrame=nil,nil
	if s.showBox then pcall(function() box=Instance.new("BillboardGui"); box.Name="ESPBox"; box.Adornee=r2
		box.Size=UDim2.new(4,0,5.5,0); box.AlwaysOnTop=true; box.MaxDistance=s.maxDistance; box.Parent=r2
		boxFrame=Instance.new("Frame"); boxFrame.Size=UDim2.new(1,0,1,0); boxFrame.BackgroundTransparency=1; boxFrame.Parent=box
		for _,d in pairs({{UDim2.new(0,0,0,0),UDim2.new(1,0,0,2)},{UDim2.new(0,0,1,-2),UDim2.new(1,0,0,2)},
			{UDim2.new(0,0,0,0),UDim2.new(0,2,1,0)},{UDim2.new(1,-2,0,0),UDim2.new(0,2,1,0)}}) do
			local line=Instance.new("Frame"); line.Name="BoxLine"; line.Position=d[1]; line.Size=d[2]; line.BackgroundColor3=s.boxColor
			line.BorderSizePixel=0; line.Parent=boxFrame end end) end
	local tracerLine=nil; if s.showTracers then tracerLine=SafeCreateTracerLine() end
	ESP.objects[target]={hl=nil,bb=bb,distLabel=distLabel,nameLabel=nameLabel,root=r2,hum=h2,head=head,box=box,boxFrame=boxFrame,
		tracerLine=tracerLine,char=char}
	
	if s.showSkeleton then CreateSkeleton(target, ESP.objects[target]) end
	if s.showGlow then CreateGlow(target, ESP.objects[target]) end
end

