	local char=target.Character; if not char then return end
	local h2=char:FindFirstChild("Humanoid"); if not h2 or h2.Health<=0 then return end
	if ESP.settings.teamCheck and target.Team==player.Team and player.Team~=nil then return end
	ESP.chamsConnections[target]={}
	local chamsList={}
	for _,part in pairs(char:GetDescendants()) do if part:IsA("BasePart") then
		local adorn=Instance.new("BoxHandleAdornment"); adorn.Name="ESPChams"; adorn.Adornee=part; adorn.AlwaysOnTop=true; adorn.ZIndex=5
		adorn.Size=part.Size+Vector3.new(0.05,0.05,0.05); adorn.Color3=ESP.settings.chamsColor; adorn.Transparency=ESP.settings.chamsTransparency
		adorn.Parent=part; table.insert(chamsList,adorn) end end
	ESP.chamsObjects[target]=chamsList
	table.insert(ESP.chamsConnections[target],h2.Died:Connect(function() task.delay(0.5,function() RemoveChams(target) end) end))
	table.insert(ESP.chamsConnections[target],char.AncestryChanged:Connect(function(_,np) if np==nil then task.delay(0.1,function() RemoveChams(target) end) end end))
end

