	for _,t2 in pairs(Players:GetPlayers()) do if t2~=player then
		local name = t2.DisplayName:lower() .. " " .. t2.Name:lower()
		if filter == "" or name:find(filter) then
			count+=1; if IsFriend(t2) then table.insert(friends,t2) else table.insert(others,t2) end
