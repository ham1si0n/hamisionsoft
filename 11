	Crosshair.guiLines={}; CHContainer.Visible=false end

local function BuildCH()
	DestroyCH(); if not Crosshair.enabled then return end; CHContainer.Visible=true
	if Crosshair.style=="Propeller" then CreatePropeller(); return end
	local vp=camera.ViewportSize; local cx,cy=vp.X/2,vp.Y/2; local col=Crosshair.color
	local sz=Crosshair.size; local gap=Crosshair.gap; local th=Crosshair.thick; local tr=1-Crosshair.opacity
	local function AL(x1,y1,x2,y2) if Crosshair.outline then local o=MakeGUILine(x1,y1,x2,y2,Color3.fromRGB(0,0,0),th+2,tr); if o then table.insert(Crosshair.guiLines,o) end end
		local l=MakeGUILine(x1,y1,x2,y2,col,th,tr); if l then table.insert(Crosshair.guiLines,l) end end
	local function AC(x,y,r,filled) if Crosshair.outline then local o=MakeGUICircle(x,y,r+1,Color3.fromRGB(0,0,0),th+1,filled,tr); if o then table.insert(Crosshair.guiLines,o) end end
		local c2=MakeGUICircle(x,y,r,col,th,filled,tr); if c2 then table.insert(Crosshair.guiLines,c2) end end
	local st=Crosshair.style
	if st=="Dot" then AC(cx,cy,th,true)
	elseif st=="Cross" then AL(cx-gap-sz,cy,cx-gap,cy); AL(cx+gap,cy,cx+gap+sz,cy); AL(cx,cy-gap-sz,cx,cy-gap); AL(cx,cy+gap,cx,cy+gap+sz)
	elseif st=="Circle" then AC(cx,cy,sz,false)
	elseif st=="Dynamic" then local spd=0; if humanoid then spd=humanoid.MoveDirection.Magnitude*(humanoid.WalkSpeed or 16) end; local dg=gap+spd*0.3
		AL(cx-dg-sz,cy,cx-dg,cy); AL(cx+dg,cy,cx+dg+sz,cy); AL(cx,cy-dg-sz,cx,cy-dg); AL(cx,cy+dg,cx,cy+dg+sz); AC(cx,cy,th,true)
	elseif st=="T-Shape" then AL(cx-gap-sz,cy,cx-gap,cy); AL(cx+gap,cy,cx+gap+sz,cy); AL(cx,cy-gap-sz,cx,cy-gap)
	elseif st=="DiamondDot" then local ds=sz*0.7
		AL(cx,cy-gap-ds,cx+gap+ds,cy); AL(cx+gap+ds,cy,cx,cy+gap+ds); AL(cx,cy+gap+ds,cx-gap-ds,cy); AL(cx-gap-ds,cy,cx,cy-gap-ds); AC(cx,cy,th,true) end
	Crosshair.lastStyle=st; Crosshair.lastSize=sz; Crosshair.lastGap=gap; Crosshair.lastThick=th end

local function UpdateCHColors() for _,o in ipairs(Crosshair.guiLines) do if typeof(o)=="Instance" and o.Parent then
	if o.BackgroundColor3~=Color3.fromRGB(0,0,0) then o.BackgroundColor3=Crosshair.color end; o.BackgroundTransparency=1-Crosshair.opacity
	elseif type(o)=="table" then for _,s in ipairs(o) do if typeof(s)=="Instance" and s.Parent then
	if s.BackgroundColor3~=Color3.fromRGB(0,0,0) then s.BackgroundColor3=Crosshair.color end; s.BackgroundTransparency=1-Crosshair.opacity end end end end end

local chRT=0
local function UpdateCH(dt) if not Crosshair.enabled then if CHContainer.Visible then DestroyCH() end; return end
	if Crosshair.style=="Propeller" then UpdatePropeller(dt); return end
	if Crosshair.rainbow then Crosshair.color=Color3.fromHSV(tick()%3/3,0.9,1); UpdateCHColors() end
	if Crosshair.style=="Dynamic" then chRT=chRT+dt; if chRT>=0.05 then chRT=0; BuildCH() end; return end
	if Crosshair.lastStyle~=Crosshair.style or Crosshair.lastSize~=Crosshair.size or Crosshair.lastGap~=Crosshair.gap
		or Crosshair.lastThick~=Crosshair.thick or Crosshair.rebuildNeeded then Crosshair.rebuildNeeded=false; BuildCH() end end

