local espUT=0
local function UpdateESP(dt)
	if not State.espEnabled then 
		for _,obj in pairs(ESP.objects) do 
			if obj.tracerLine then pcall(function() obj.tracerLine.Visible=false end) end
			if obj.skeleton then
				for _, line in pairs(obj.skeleton) do
					pcall(function() line.Visible = false end)
				end
			end
		end 
		return 
	end
	espUT=espUT+dt; local ud=espUT>=0.1; if ud then espUT=0 end
	local originPt=GetTracerOriginPoint(); local myPos=rootPart and rootPart.Position or Vector3.zero
	for target,obj in pairs(ESP.objects) do
		if not obj.root or not obj.root.Parent then task.defer(function() RemoveESP(target) end); continue end
		local tp=obj.root.Position; local dist=(myPos-tp).Magnitude
		if ud and obj.distLabel and obj.distLabel.Parent then obj.distLabel.Text="["..math.floor(dist).."M]" end
		if obj.tracerLine~=nil and ESP.settings.showTracers then
			if dist<=ESP.settings.maxDistance then local sp,on=camera:WorldToViewportPoint(tp)
				if on then pcall(function() obj.tracerLine.Visible=true; obj.tracerLine.From=originPt
					obj.tracerLine.To=Vector2.new(sp.X,sp.Y); obj.tracerLine.Color=ESP.settings.tracerColor end)
				else pcall(function() obj.tracerLine.Visible=false end) end
			else pcall(function() obj.tracerLine.Visible=false end) end
		elseif obj.tracerLine~=nil then pcall(function() obj.tracerLine.Visible=false end) end
		
		if ESP.settings.showSkeleton and obj.skeleton then
			UpdateSkeleton(target, obj)
		end
	end end

