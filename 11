-- Подключаемся к событиям смерти с улучшенным определением убийцы
local function setupDeathListeners(plr)
	plr.CharacterAdded:Connect(function(char)
		local hum = char:WaitForChild("Humanoid")
		hum.Died:Connect(function()
			local killer = nil
			pcall(function()
				-- Пытаемся найти тег creator (ObjectValue)
				local creatorTag = hum:FindFirstChild("creator")
				if creatorTag and creatorTag:IsA("ObjectValue") and creatorTag.Value and creatorTag.Value:IsA("Player") then
					killer = creatorTag.Value
				else
					-- Пробуем атрибут
					local lastAttacker = hum:GetAttribute("LastAttacker")
					if lastAttacker then
						if typeof(lastAttacker) == "Instance" and lastAttacker:IsA("Player") then
							killer = lastAttacker
						elseif typeof(lastAttacker) == "string" then
							killer = Players:FindFirstChild(lastAttacker)
						end
					end
				end
			end)
			onCharacterDied(plr, killer)
		end)
	end)
end

for _, plr in pairs(Players:GetPlayers()) do
	if plr ~= player then
		setupDeathListeners(plr)
	end
end
