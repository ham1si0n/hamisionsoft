local function BuildScroll(container,zBase,topOffset)
	topOffset=topOffset or 58
	local scroll=Instance.new("ScrollingFrame"); scroll.Size=UDim2.new(1,-16,1,-(topOffset+6)); scroll.Position=UDim2.new(0,8,0,topOffset)
	scroll.BackgroundTransparency=1; scroll.BorderSizePixel=0; scroll.ScrollBarThickness=4
	scroll.ScrollBarImageColor3=C.DashColor; scroll.ScrollBarImageTransparency=0.3
	scroll.CanvasSize=UDim2.new(0,0,0,0); scroll.ZIndex=zBase+2; scroll.Parent=container
	local layout=Instance.new("UIListLayout"); layout.Padding=UDim.new(0,6); layout.Parent=scroll
	layout:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function() scroll.CanvasSize=UDim2.new(0,0,0,layout.AbsoluteContentSize.Y+10) end)
	table.insert(GUI.scrollRefs,scroll); return scroll end

