local function PositionSpoof()
	if not State.positionSpoofEnabled then return end
	if not rootPart then return end
	
	State.spoofedPosition = rootPart.Position
	
	local positionRemote = nil
	for _, v in pairs(ReplicatedStorage:GetDescendants()) do
		if v:IsA("RemoteEvent") and (v.Name:lower():match("position") or v.Name:lower():match("move") or v.Name:lower():match("update")) then
			positionRemote = v
			break
		end
	end
	
	if positionRemote then
		local oldFire = positionRemote.FireServer
		positionRemote.FireServer = function(self, ...)
			local args = {...}
			if typeof(args[1]) == "Vector3" then
				args[1] = State.spoofedPosition
				return oldFire(self, unpack(args))
			end
			return oldFire(self, ...)
		end
	end
	
