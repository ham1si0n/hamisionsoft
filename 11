function ConfigSystem.RegisterToggle(key,setFn) ConfigSystem.setStateCallbacks[key]=setFn end
function ConfigSystem.RegisterSlider(key,setFn) ConfigSystem.sliderSetCallbacks[key]=setFn end

function ConfigSystem.ApplyConfig(cfg)
	if not cfg then return false end
	if cfg.theme and Themes[cfg.theme] then ApplyTheme(cfg.theme) end
	if cfg.guiOpacity then State.guiOpacity=cfg.guiOpacity end
	local sliderMap={
		speed={val=cfg.speedValue,state="speedValue"},jump={val=cfg.jumpValue,state="jumpValue"},
		gravity={val=cfg.gravityValue,state="gravityValue"},flySpeed={val=cfg.flySpeed,state="flySpeed"},
		spinSpeed={val=cfg.spinSpeed,state="spinSpeed"},fov={val=cfg.fovValue,state="fovValue"},
		killAuraRadius={val=cfg.killAuraRadius,state="killAuraRadius"},
	}
	for key,info in pairs(sliderMap) do if info.val~=nil then State[info.state]=info.val
		if ConfigSystem.sliderSetCallbacks[key] then ConfigSystem.sliderSetCallbacks[key](info.val) end end end
	if cfg.speedValue then if humanoid then humanoid.WalkSpeed=cfg.speedValue end end
	if cfg.jumpValue then if humanoid then humanoid.JumpPower=cfg.jumpValue end end
	if cfg.gravityValue then workspace.Gravity=cfg.gravityValue end
	if cfg.fovValue then camera.FieldOfView=cfg.fovValue end
	if cfg.flyToggleKey then local ok,kc=pcall(function() return Enum.KeyCode[cfg.flyToggleKey] end)
		if ok and kc then State.flyToggleKey=kc end end
	if cfg.flyToggleButtonEnabled ~= nil then State.flyToggleButtonEnabled = cfg.flyToggleButtonEnabled end
	if cfg.speedBypassEnabled ~= nil then State.speedBypassEnabled = cfg.speedBypassEnabled end
	if cfg.positionSpoofEnabled ~= nil then State.positionSpoofEnabled = cfg.positionSpoofEnabled end
	if cfg.networkTunnelingEnabled ~= nil then State.networkTunnelingEnabled = cfg.networkTunnelingEnabled end
	if cfg.skeletonESPEnabled ~= nil then State.skeletonESPEnabled = cfg.skeletonESPEnabled end
	if cfg.espGlowEnabled ~= nil then State.espGlowEnabled = cfg.espGlowEnabled end
	if cfg.telekillEnabled ~= nil then State.telekillEnabled = cfg.telekillEnabled end
	if cfg.notificationsEnabled ~= nil then State.notificationsEnabled = cfg.notificationsEnabled end
	if cfg.clickTpKey then local ok,kc=pcall(function() return Enum.KeyCode[cfg.clickTpKey] end)
		if ok and kc then State.clickTpKey=kc; if tpKeyBtn then tpKeyBtn.Text=kc.Name; tpKeyBtn.BackgroundColor3=C.Green end end end
	if cfg.clickTpEnabled~=nil then State.clickTpEnabled=cfg.clickTpEnabled
		if ConfigSystem.setStateCallbacks["clickTp"] then ConfigSystem.setStateCallbacks["clickTp"](cfg.clickTpEnabled) end end
	if cfg.aimbot and cfg.aimbot.activationKey then
		local ok, kc = pcall(function() return Enum.KeyCode[cfg.aimbot.activationKey] end)
		if ok and kc then Aimbot.key = kc; if aimKeyBtn then aimKeyBtn.Text = kc.Name; aimKeyBtn.BackgroundColor3 = C.Green end end
	end
	if cfg.esp then local e=cfg.esp
		for k,_ in pairs({showNames=1,showDistance=1,showHealth=1,showBox=1,showTracers=1,showSkeleton=1,showGlow=1}) do if e[k]~=nil then ESP.settings[k]=e[k] end end
		ESP.settings.tracerOrigin=e.tracerOrigin or "Bottom"
		ESP.settings.fillTransparency=e.fillTransparency or 0.6; ESP.settings.chamsTransparency=e.chamsTransparency or 0.3
		ESP.settings.textSize=e.textSize or 12; ESP.settings.maxDistance=e.maxDistance or 10000
		ESP.settings.rainbowEnabled=e.rainbowEnabled or false; ESP.settings.teamCheck=e.teamCheck or false
		if e.boxColor then ESP.settings.boxColor=TableToColor3(e.boxColor) end
		if e.tracerColor then ESP.settings.tracerColor=TableToColor3(e.tracerColor) end
		if e.nameColor then ESP.settings.nameColor=TableToColor3(e.nameColor) end
		if e.chamsColor then ESP.settings.chamsColor=TableToColor3(e.chamsColor) end
		if e.healthBarColor then ESP.settings.healthBarColor=TableToColor3(e.healthBarColor) end
		if e.healthBgColor then ESP.settings.healthBgColor=TableToColor3(e.healthBgColor) end
		if e.glowColor then ESP.settings.glowColor=TableToColor3(e.glowColor) end end
	if cfg.aimbot then local a=cfg.aimbot
		Aimbot.fov=a.fov or 150; Aimbot.smooth=a.smooth or 0.12; Aimbot.targetPart=a.targetPart or "Head"
		Aimbot.teamCheck=a.teamCheck or false; Aimbot.visCheck=a.visCheck or false
		Aimbot.fovVisible=a.fovVisible~=nil and a.fovVisible or true
		Aimbot.prediction=a.prediction or false; Aimbot.predictAmount=a.predictAmount or 0.1
		if ConfigSystem.sliderSetCallbacks["aimbotFov"] then ConfigSystem.sliderSetCallbacks["aimbotFov"](Aimbot.fov) end
		if ConfigSystem.sliderSetCallbacks["aimbotSmooth"] then ConfigSystem.sliderSetCallbacks["aimbotSmooth"](math.floor(Aimbot.smooth*100)) end
		if ConfigSystem.sliderSetCallbacks["aimbotPredAmt"] then ConfigSystem.sliderSetCallbacks["aimbotPredAmt"](math.floor(Aimbot.predictAmount*100)) end end
	if cfg.crosshair then local ch=cfg.crosshair
