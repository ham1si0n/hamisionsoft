-- KILL AURA
local function DestroyKillAuraCircle() for _,p in ipairs(State.killAuraCircleParts) do if p and p.Parent then p:Destroy() end end; State.killAuraCircleParts={} end

local function CreateKillAuraCircle()
	DestroyKillAuraCircle(); if not State.killAuraEnabled or not rootPart or not rootPart.Parent then return end
	local segs=36; local radius=State.killAuraRadius; local angleStep=(2*math.pi)/segs
	for i=0,segs-1 do local angle=i*angleStep
		local x1,z1=math.cos(angle)*radius,math.sin(angle)*radius
		local x2,z2=math.cos(angle+angleStep*0.6)*radius,math.sin(angle+angleStep*0.6)*radius
		local midX,midZ=(x1+x2)/2,(z1+z2)/2; local dx,dz=x2-x1,z2-z1
		local segLen=math.sqrt(dx*dx+dz*dz); local segAngle=math.atan2(dz,dx)
		local part=Instance.new("Part"); part.Name="KillAuraDash"; part.Anchored=true; part.CanCollide=false
		part.Material=Enum.Material.Neon; part.Color=Color3.fromRGB(255,255,255)
		part.Size=Vector3.new(segLen,0.15,0.15); part.Transparency=0.2; part.CastShadow=false; part.Parent=workspace
		part.CFrame=CFrame.new(rootPart.Position+Vector3.new(midX,-2.5,midZ))*CFrame.Angles(0,-segAngle,0)
		table.insert(State.killAuraCircleParts,part) end end

local function UpdateKillAuraCircle()
	if not State.killAuraEnabled then DestroyKillAuraCircle(); return end
	if not rootPart or not rootPart.Parent then return end
	if #State.killAuraCircleParts==0 then CreateKillAuraCircle(); return end
	local segs=#State.killAuraCircleParts; local radius=State.killAuraRadius
	local angleStep=(2*math.pi)/segs; local basePos=rootPart.Position
	for i,part in ipairs(State.killAuraCircleParts) do if not part or not part.Parent then CreateKillAuraCircle(); return end
		local idx=i-1; local angle=idx*angleStep
		local x1,z1=math.cos(angle)*radius,math.sin(angle)*radius
		local x2,z2=math.cos(angle+angleStep*0.6)*radius,math.sin(angle+angleStep*0.6)*radius
		local midX,midZ=(x1+x2)/2,(z1+z2)/2; local dx,dz=x2-x1,z2-z1
		local segLen=math.sqrt(dx*dx+dz*dz); local segAngle=math.atan2(dz,dx)
		part.Size=Vector3.new(segLen,0.15,0.15)
		part.CFrame=CFrame.new(basePos+Vector3.new(midX,-2.5,midZ))*CFrame.Angles(0,-segAngle,0)
		local pulse=(math.sin(tick()*2+idx*0.2)+1)/2
		part.Color=Color3.fromRGB(255,math.floor(255-30*pulse),math.floor(255-30*pulse))
		part.Transparency=0.15+0.25*pulse end end

local function UpdateKillAura() if not State.killAuraEnabled or not rootPart or not rootPart.Parent then return end
	local myPos=rootPart.Position
	for _,target in pairs(Players:GetPlayers()) do if target==player then continue end; if IsImmortal(target) then continue end
		local tc=target.Character; if not tc then continue end; local tr=tc:FindFirstChild("HumanoidRootPart"); local th=tc:FindFirstChild("Humanoid")
		if not tr or not th or th.Health<=0 then continue end; if (myPos-tr.Position).Magnitude>State.killAuraRadius then continue end
		tr.CFrame=rootPart.CFrame*CFrame.new(0,0,-3); tr.AssemblyLinearVelocity=Vector3.zero; tr.AssemblyAngularVelocity=Vector3.zero end end

task.spawn(function() while State.guiEnabled do if State.killAuraEnabled then UpdateKillAura() end; task.wait(0.15) end end)

