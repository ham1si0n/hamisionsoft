-- NETWORK TUNNELING
local function SetupNetworkTunneling()
	if not State.networkTunnelingEnabled then return end
	
	local remotes = {}
	for _, v in pairs(game:GetDescendants()) do
		if v:IsA("RemoteEvent") or v:IsA("RemoteFunction") then
			table.insert(remotes, v)
		end
	end
	
	local antiCheatRemotes = {}
	for _, remote in pairs(remotes) do
		local name = remote.Name:lower()
		if name:match("anticheat") or name:match("anticheat") or 
		   name:match("speed") or name:match("position") or
		   name:match("detect") or name:match("check") or
		   name:match("validation") or name:match("verify") then
			table.insert(antiCheatRemotes, remote)
			table.insert(State.blockedRemotes, remote)
		end
	end
	
	Network.originalFireServer = Instance.new("RemoteEvent").FireServer
	Network.originalInvokeServer = Instance.new("RemoteFunction").InvokeServer
	
	for _, remote in pairs(antiCheatRemotes) do
		if remote:IsA("RemoteEvent") then
			remote.FireServer = function() 
				return 
			end
		elseif remote:IsA("RemoteFunction") then
			remote.InvokeServer = function()
				return nil
			end
		end
	end
	
	local tunnel = Instance.new("Folder")
	tunnel.Name = "NetworkTunnel_"..math.random(1000, 9999)
	tunnel.Parent = game:GetService("CoreGui")
	
	local netLabel = Instance.new("TextLabel")
	netLabel.Size = UDim2.new(0, 200, 0, 20)
	netLabel.Position = UDim2.new(0, 10, 0.6, -10)
	netLabel.BackgroundTransparency = 0.5
	netLabel.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
	netLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
	netLabel.Text = "NETWORK: BLOCKED "..#antiCheatRemotes.." REMOTES"
	netLabel.Font = PIXEL_FONT
	netLabel.TextSize = 10
	netLabel.Parent = ScreenGui
	
	task.spawn(function()
		while State.networkTunnelingEnabled do
			netLabel.Text = "NETWORK: BLOCKED "..#antiCheatRemotes.." REMOTES"
			task.wait(1)
		end
		netLabel:Destroy()
		for _, remote in pairs(antiCheatRemotes) do
			if remote:IsA("RemoteEvent") then
				remote.FireServer = Network.originalFireServer
			elseif remote:IsA("RemoteFunction") then
				remote.InvokeServer = Network.originalInvokeServer
			end
		end
	end)
	
	ShowNotification("Network Tunnel Active: Blocked "..#antiCheatRemotes.." AntiCheat Remotes", C.Green, 3)
end

