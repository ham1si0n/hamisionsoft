-- THEME SYNC
local function SyncAllToTheme()
	for _,p in ipairs(GUI.glassPanels) do
		if p.glass and p.glass.Parent then TweenService:Create(p.glass,TweenInfo.new(0.5),{BackgroundColor3=C.Background}):Play() end
		if p.overlay and p.overlay.Parent then TweenService:Create(p.overlay,TweenInfo.new(0.5),{BackgroundColor3=C.Background}):Play() end
		if p.dashes then for _,d in ipairs(p.dashes) do if d and d.Parent then TweenService:Create(d,TweenInfo.new(0.5),{BackgroundColor3=C.DashColor}):Play() end end end
		local stroke = p.glass:FindFirstChildOfClass("UIStroke")
		if stroke then stroke.Color = C.DashColor end
	end
	for _,p in ipairs(GUI.headerPanels) do
		if p.header and p.header.Parent then TweenService:Create(p.header,TweenInfo.new(0.5),{BackgroundColor3=C.BackgroundLight}):Play() end
		if p.fix and p.fix.Parent then TweenService:Create(p.fix,TweenInfo.new(0.5),{BackgroundColor3=C.BackgroundLight}):Play() end end
	for _,scroll in ipairs(GUI.scrollRefs) do if scroll and scroll.Parent then scroll.ScrollBarImageColor3=C.DashColor end end
	for _,fill in ipairs(GUI.sliderFills) do if fill and fill.Parent then TweenService:Create(fill,TweenInfo.new(0.5),{BackgroundColor3=C.DashColor}):Play() end end
	for _,lbl in ipairs(GUI.textLabels) do if lbl and lbl.Parent then lbl.TextColor3=C.Text end end
	RefreshSnowColors()
	for _,fn in ipairs(GUI.themeCallbacks) do fn() end
	if iconStroke then
		iconStroke.Color = C.DashColor
	end
end

local function SyncOpacity()
	for _,p in ipairs(GUI.glassPanels) do
		if p.glass and p.glass.Parent then TweenService:Create(p.glass,TweenInfo.new(0.4),{BackgroundTransparency=State.guiOpacity}):Play() end
		if p.overlay and p.overlay.Parent then TweenService:Create(p.overlay,TweenInfo.new(0.4),{BackgroundTransparency=0.85}):Play() end end end

local function RegTheme(fn) table.insert(GUI.themeCallbacks,fn) end

