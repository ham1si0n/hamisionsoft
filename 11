		TweenService:Create(closeBtn, TweenInfo.new(0.2), {BackgroundColor3 = Color3.fromRGB(255, 50, 70)}):Play()
	end)
	closeBtn.MouseLeave:Connect(function()
		TweenService:Create(closeBtn, TweenInfo.new(0.2), {BackgroundColor3 = C.CloseBtn}):Play()
	end)
	
	table.insert(GUI.headerPanels, {header=header, fix=fix})
	return header, closeBtn, fix, titleLbl
